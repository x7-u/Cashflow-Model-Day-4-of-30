# Copy this file to .env in the repo root and fill in real values.
# Never commit .env; it is in .gitignore.

# Required. Get one at https://platform.deepseek.com/.
DEEPSEEK_API_KEY=sk-placeholder

# Optional override; deepseek-chat resolves to V4 latest.
DEEPSEEK_MODEL_FAST=deepseek-chat

# Optional, only override if you proxy.
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
